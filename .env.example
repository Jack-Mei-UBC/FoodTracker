# General
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=foodtracker
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/foodtracker

# Cache & Queue (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# OCR service (vision LLM via OpenRouter)
OPENROUTER_API_KEY=
OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# URL the Next.js server uses to reach the OCR service.
# Inside docker-compose this is overridden to http://ocr-service:8000;
# the localhost value is for running `next dev` outside Docker.
OCR_SERVICE_URL=http://localhost:8000

# USDA FoodData Central (nutrition lookup) - get a key at https://fdc.nal.usda.gov/api-key-signup
FDC_API_KEY=your_fdc_api_key_here
