# General
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=foodtracker
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/foodtracker

# Cache & Queue (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Frontend
# BAKED INTO THE CLIENT BUNDLE at build/compile time, so this must be an address
# the BROWSER can reach — not one the container can reach. `localhost` is correct
# only when the browser is on this same machine.
#
# Testing from a PHONE or another device on the LAN? Set this to the host's LAN
# IP, then recreate the frontend (`docker compose up -d --force-recreate frontend`).
# Leaving it as localhost makes the phone call ITSELF, which shows up as
# "backend server unreachable" while the page itself loads fine.
#   NEXT_PUBLIC_API_URL=http://192.168.1.130:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# OpenRouter (vision + text LLMs)
OPENROUTER_API_KEY=

# ── Model pool (4-list contract: free/paid × image/text) ────────────────────
# The worker runs all FREE_IMAGE_MODELS in parallel across DIFFERENT scans and
# retries a scan on the next model if one fails (worker/src/modelPool.ts). The
# backend tries FREE_TEXT_MODELS in failover order for meal/tag/merge
# (backend/src/modelPool.ts). Comma-separated. An empty FREE_* list falls back
# to the legacy singular env below, so old .env files keep working.
#
# IMPORTANT: the worker's ocr-queue concurrency == the number of FREE_IMAGE_MODELS
# (+ paid). A single entry means ONE receipt is read at a time. List several to
# actually scan in parallel. Models below were verified against a real receipt.
FREE_IMAGE_MODELS=google/gemma-4-26b-a4b-it:free,openrouter/free,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free,nvidia/nemotron-nano-12b-v2-vl:free
PAID_IMAGE_MODELS=
FREE_TEXT_MODELS=google/gemma-4-26b-a4b-it:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-20b:free,nvidia/nemotron-nano-9b-v2:free
PAID_TEXT_MODELS=
# Global default for the "use paid models" toggle (per-batch checkbox on /staging
# overrides this for image jobs). true|false.
USE_PAID_MODELS=false
# Per-scan retry cap — how many models a single OCR scan cycles through.
OCR_MAX_ATTEMPTS=3

# Legacy single-model envs (seed the FREE_* lists when those are empty; still
# honored as single-model overrides where noted).
OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
MEAL_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# Optional single-model overrides that bypass the text pool entirely.
TAG_MODEL=
MERGE_MODEL=

# URL other services use to reach the OCR service (the worker's OCR calls).
# Inside docker-compose this is overridden to http://ocr-service:8000;
# the localhost value is for running outside Docker.
OCR_SERVICE_URL=http://localhost:8000

# USDA FoodData Central (nutrition lookup) - get a key at https://fdc.nal.usda.gov/api-key-signup
FDC_API_KEY=your_fdc_api_key_here
