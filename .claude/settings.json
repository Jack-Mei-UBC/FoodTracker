{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PROJECT_DIR}/scripts/hooks/pre-bash-guard.ps1"
            ],
            "timeout": 30,
            "statusMessage": "Guarding against destructive commands / undocumented pushes"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PROJECT_DIR}/scripts/hooks/stop-typecheck.ps1"
            ],
            "timeout": 120,
            "statusMessage": "Typechecking edited services"
          },
          {
            "type": "command",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PROJECT_DIR}/scripts/smoke-test.ps1"
            ],
            "timeout": 90,
            "statusMessage": "Running FoodTracker smoke tests"
          }
        ]
      }
    ]
  }
}
