# Environment files - NEVER commit these
.env
.env.local
.env.*.local
*.env

# Node
node_modules/
npm-debug.log*
yarn-debug.log*

# Next.js
frontend/.next/
frontend/out/
frontend/next-env.d.ts
frontend/test-results/

# Python
__pycache__/
*.pyc

# Build outputs
backend/dist/
worker/dist/
frontend/tsconfig.tsbuildinfo
frontend/next-env.d.ts

# Python bytecode (ocr-service)
__pycache__/
*.py[cod]

# Docker volumes (local state)
postgres_data/
redis_data/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Playwright (UI test net) — artifacts only; specs + fixtures ARE committed
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/.playwright/

# Playwright artifacts live OUTSIDE frontend/ so the dev container's file
# watcher (bind mount + polling) can't see them and recompile mid-test.
.playwright-artifacts/
